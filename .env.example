# Mentors HQ — environment template. Copy to .env.local and fill in.

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only. Service-role key — full DB access. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Hires on/before this ISO date are auto-flagged as founding team.
APP_LAUNCH_DATE=2026-07-01

# Public site URL (used for invite redirect links). In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
